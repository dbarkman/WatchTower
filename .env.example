# Discord webhook for alerts (optional — leave empty to skip Discord)
DISCORD_WEBHOOK_URL=

# Ntfy base URL (default: https://ntfy.sh)
NTFY_URL=https://ntfy.sh

# Fleet-wide ntfy kill switch. Set to true to suppress ALL ntfy pushes
# (Discord is unaffected). Use when an external monitor (e.g. UptimeRobot)
# is the primary alert path and ntfy is redundant.
WT_NTFY_DISABLED=false
