# WatchTower monitoring targets
#
# Each target defines a remote endpoint to health-check.
# Copy this file to targets.yaml and customize for your setup.

targets:
  - name: "Web Server"
    url: "https://example.com/health"
    ntfy_topic: "WEB1-Up"
    # How many consecutive failures before alerting (default: 2)
    failure_threshold: 2
    # Request timeout in seconds (default: 10)
    timeout: 10

  - name: "API Server"
    url: "https://api.example.com/health/daemon"
    ntfy_topic: "API1-Up"

  - name: "Database Server"
    url: "https://db.example.com/health"
    ntfy_topic: "DB1-Up"
    failure_threshold: 3
