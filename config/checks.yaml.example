# WatchTower Health Checks Configuration
#
# Copy to checks.yaml and customize for each server.
# Run: uv run python -m watchtower.report --config config/checks.yaml
#
# Omit a check section entirely to skip it.

# Server identity (used in report header)
server_name: web1

# Ntfy topic for push alerts (only fires when issues found)
ntfy_topic: "WT-Health"

# Set true to send ntfy even when everything is OK
ntfy_always: false

checks:
  # Disk space — alert when partitions get full
  disk:
    partitions: ["/"]
    warn_pct: 80
    critical_pct: 90

  # Memory/swap — alert on high swap usage
  memory:
    swap_warn_pct: 50
    swap_critical_pct: 80

  # OOM kills — scan syslog for out-of-memory events
  oom:
    log_path: /var/log/messages
    warn_count: 1       # any OOM kill = warning
    critical_count: 5   # 5+ in 24h = critical

  # Service status — verify expected services are running
  services:
    expected:
      - httpd
      - mariadb
      - fail2ban
      - firewalld

  # Auth logs — failed SSH attempts
  auth:
    log_path: /var/log/secure
    warn_threshold: 50
    critical_threshold: 200

  # fail2ban jail status
  fail2ban: {}

  # SSL certificates — warn before expiry
  # Certs auto-discovered from /etc/letsencrypt/live/ if not specified
  ssl:
    warn_days: 14
    critical_days: 7
    # Optionally list specific cert paths:
    # certs:
    #   - /etc/letsencrypt/live/example.com/fullchain.pem

  # Process memory — watch specific processes for leaks
  process_rss:
    processes:
      - name: one_cent_trader_ws.py
        warn_mb: 500
        critical_mb: 1000

  # On-chain wallet balances — alert when running low on gas or capital.
  # Uses raw JSON-RPC (no web3 dep). Native chain coin if `token` omitted.
  # Each probe specifies its own RPC and thresholds.
  wallets:
    probes:
      # Polygon native MATIC (gas for Polymarket redemptions)
      - name: "Polygon MATIC"
        rpc: "https://polygon-bor-rpc.publicnode.com"
        wallet: "0x..."
        decimals: 18
        warn_below: 30
        critical_below: 5
      # Polygon USDC.e (Polymarket trading capital)
      - name: "Polygon USDC.e"
        rpc: "https://polygon-bor-rpc.publicnode.com"
        wallet: "0x..."
        token: "0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174"
        decimals: 6
        warn_below: 100
        critical_below: 50
      # Base ETH (gas for Limitless redemptions)
      - name: "Base ETH"
        rpc: "https://mainnet.base.org"
        wallet: "0x..."
        decimals: 18
        warn_below: 0.0005
        critical_below: 0.0001
      # Base USDC (Limitless trading capital)
      - name: "Base USDC"
        rpc: "https://mainnet.base.org"
        wallet: "0x..."
        token: "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913"
        decimals: 6
        warn_below: 90
        critical_below: 50

  # Cross-server peer reachability — each server pings the others' /health
  # endpoints. Used by both daily digest and the high-cadence
  # peers_monitor (which runs every 15 min with state-throttled alerts).
  # List ONLY the OTHER servers from each server's checks.yaml.
  peers:
    timeout_seconds: 5
    alert_repeat_hours: 4   # while a peer stays down, re-alert this often
    hosts:
      - name: web1
        url: http://23.239.29.130:8100/health
      - name: web2
        url: http://104.237.153.4:8100/health
      # - name: mum1
      #   url: http://192.46.213.107:8100/health
